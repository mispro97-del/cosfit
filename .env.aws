# ============================================================
# COSFIT - AWS Production Environment Variables
# ============================================================
# AWS Secrets Manager에서 주입되는 변수는 여기에 포함하지 않음
# (DATABASE_URL, NEXTAUTH_SECRET 등은 ECS Task Definition의
#  secrets 섹션에서 Secrets Manager ARN으로 참조)
#
# 이 파일은 ECS Task Definition의 environment 섹션이나
# App Runner의 환경 변수 설정에 해당하는 값만 포함
# ============================================================

# ── App ──
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1

# ── Public (빌드 시 번들에 포함됨) ──
NEXT_PUBLIC_APP_NAME=COSFIT
NEXT_PUBLIC_APP_URL=https://cosfit.kr
NEXT_PUBLIC_API_BASE=/api/v1

# ── AI ──
COSFIT_AI_MODEL=gpt-4o

# ── 식약처 API ──
KFDA_API_BASE_URL=https://openapi.foodsafetykorea.go.kr/api

# ── AWS ──
AWS_REGION=ap-northeast-1
# AWS_S3_BUCKET=cosfit-uploads
