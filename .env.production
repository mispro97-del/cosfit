# ============================================================
# COSFIT - Production Environment Variables
# ============================================================
# 이 파일을 .env.production.local로 복사한 후
# 실제 값을 입력하세요. 절대 Git에 커밋하지 마세요!
# ============================================================

# ── Database ──────────────────────────────────────────────────
# Supabase, Neon, PlanetScale 등 Managed PostgreSQL 권장
# Connection Pooling(PgBouncer) URL을 사용하세요
DATABASE_URL="postgresql://user:password@db-host:5432/cosfit?schema=public&connection_limit=10"

# Prisma Migrate 전용 Direct URL (Pooling 미경유)
DIRECT_URL="postgresql://user:password@db-host:5432/cosfit?schema=public"

# ── Authentication (NextAuth) ────────────────────────────────
# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://cosfit.kr"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ── AI / LLM ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
COSFIT_AI_MODEL="gpt-4o"

# ── 식약처 공공데이터 API (FR-D01) ───────────────────────────
KFDA_API_KEY=""
KFDA_API_BASE_URL="https://openapi.foodsafetykorea.go.kr/api"

# ── PG 결제 (Toss Payments) ──────────────────────────────────
# 실제 연동 시 활성화
# TOSS_CLIENT_KEY="live_ck_..."
# TOSS_SECRET_KEY="live_sk_..."
# TOSS_WEBHOOK_SECRET=""

# ── Storage (이미지 업로드) ──────────────────────────────────
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET="cosfit-uploads"
# AWS_S3_REGION="ap-northeast-1"

# ── Monitoring & Logging ─────────────────────────────────────
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# ── App Configuration ────────────────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_NAME="COSFIT"
NEXT_PUBLIC_APP_URL="https://cosfit.kr"
NEXT_PUBLIC_API_BASE="/api/v1"

# Google Search Console
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ── Rate Limiting (Production) ───────────────────────────────
# Redis URL (Upstash, ElastiCache 등)
# REDIS_URL="redis://default:password@host:6379"

# ── Cron Jobs / Background Tasks ─────────────────────────────
# CRON_SECRET="internal-cron-secret-key"
